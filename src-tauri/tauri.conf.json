{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacVdesktop",
  "version": "0.1.0",
  "identifier": "com.alanbulan.macvdesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "MacVdesktop",
        "width": 1600,
        "height": 1000,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
